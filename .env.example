# Copie para .env e preencha. Nunca commite .env com segredos reais.
# Ver README.md para detalhes.

# Django
DJANGO_SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria
DJANGO_DEBUG=1
ALLOWED_HOSTS=
FRONTEND_URL=http://localhost:5173

# Banco: vazio ou ausente = SQLite local (db.sqlite3)
# Exemplo PostgreSQL: postgresql://user:pass@localhost:5432/social_automation
DATABASE_URL=

# Celery / Redis
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=django-db
CELERY_TIMEZONE=America/Sao_Paulo
CELERY_ENABLE_UTC=0
# CELERY_EAGER=1

# Mídia e FFmpeg
MEDIA_ROOT=storage/media
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# Idioma / fuso
LANGUAGE_CODE=pt-br
TIME_ZONE=America/Sao_Paulo

# Criptografia de segredos no banco (Fernet derivado — use string forte em produção)
SOCIAL_ENCRYPTION_KEY=troque-por-chave-forte-unica

# Whisper / GPU (opcional)
WHISPER_DEVICE=cpu
WHISPER_MODEL=small
# WHISPER_DEBUG_GPU=0

# LLM (análise de cortes)
# OPENAI_API_KEY=
XAI_API_KEY=

# Google / YouTube OAuth (por ambiente; registre redirect URIs no Google Cloud)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://127.0.0.1:8000/social/youtube/callback/
YOUTUBE_CHECK_CLIENT_ID=
YOUTUBE_CHECK_CLIENT_SECRET=
YOUTUBE_CHECK_REDIRECT_URI=http://127.0.0.1:8000/api/youtube/factory-check-callback/
# YOUTUBE_API_KEY=

# Upload-Post (TikTok etc.)
# UPLOAD_POST_API_KEY=

# yt-dlp
# YTDLP_COOKIES_FILE=/caminho/absoluto/youtube_cookies.txt
# YTDLP_COOKIES_FROM_BROWSER=chrome
