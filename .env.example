# Copy to .env and fill in. Never commit .env with real secrets.
# See README.md for details.

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-key
DJANGO_DEBUG=1
ALLOWED_HOSTS=
FRONTEND_URL=http://localhost:5173

# Database: empty or unset = local SQLite (db.sqlite3)
# PostgreSQL example: postgresql://user:pass@localhost:5432/social_automation
DATABASE_URL=

# Celery / Redis
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=django-db
CELERY_TIMEZONE=America/Sao_Paulo
CELERY_ENABLE_UTC=0
# CELERY_EAGER=1

# Media and FFmpeg
MEDIA_ROOT=storage/media
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# Locale / timezone
LANGUAGE_CODE=en-us
TIME_ZONE=America/Sao_Paulo

# Database secret encryption (Fernet-derived — use a strong unique string in production)
SOCIAL_ENCRYPTION_KEY=replace-with-a-strong-unique-key

# Whisper / GPU (optional)
WHISPER_DEVICE=cpu
WHISPER_MODEL=small
# WHISPER_DEBUG_GPU=0

# LLM (cut analysis)
# OPENAI_API_KEY=
XAI_API_KEY=

# Google / YouTube OAuth (per environment; register redirect URIs in Google Cloud)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://127.0.0.1:8000/social/youtube/callback/
YOUTUBE_CHECK_CLIENT_ID=
YOUTUBE_CHECK_CLIENT_SECRET=
YOUTUBE_CHECK_REDIRECT_URI=http://127.0.0.1:8000/api/youtube/factory-check-callback/
# YOUTUBE_API_KEY=

# Upload-Post (TikTok, etc.)
# UPLOAD_POST_API_KEY=

# yt-dlp
# YTDLP_COOKIES_FILE=/absolute/path/youtube_cookies.txt
# YTDLP_COOKIES_FROM_BROWSER=chrome
